{
  "name": "giow-downloader",
  "version": "1.0.0",
  "description": "GIOW Video Downloader",
  "author": "GIOW",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win portable --publish never",
    "build:mac": "electron-builder --mac dmg --publish never",
    "build:linux": "electron-builder --linux AppImage --publish never"
  },
  "build": {
    "appId": "pro.giow.downloader",
    "productName": "GIOW Downloader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "server/**/*"
    ],
    "asarUnpack": [
      "server/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "GIOW-Downloader-${version}-win.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "GIOW-Downloader-${version}-mac.dmg"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "artifactName": "GIOW-Downloader-${version}-linux.AppImage",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
